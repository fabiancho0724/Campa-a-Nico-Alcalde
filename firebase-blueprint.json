{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile with role and settings",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user"
        },
        "role": {
          "type": "string",
          "enum": ["Administrador", "Analista", "Consultor", "Usuario Registrado", "Usuario Invitado"],
          "description": "User's role for RBAC"
        },
        "email": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "photoURL": {
          "type": "string"
        },
        "createdAt": {
          "type": "timestamp"
        },
        "updatedAt": {
          "type": "timestamp"
        }
      },
      "required": ["userId", "role", "email"]
    },
    "Proposal": {
      "title": "Proposal",
      "description": "A campaign proposal",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["id", "title", "content", "authorId", "createdAt"]
    },
    "AgendaItem": {
      "title": "AgendaItem",
      "description": "An agenda event",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "timestamp" },
        "location": { "type": "string" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["id", "title", "date", "location", "authorId", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A user comment on an item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "content": { "type": "string" },
        "userId": { "type": "string" },
        "targetId": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["id", "content", "userId", "targetId", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "proposals/{proposalId}": {
      "schema": "Proposal",
      "description": "Proposals collection"
    },
    "agenda/{agendaId}": {
      "schema": "AgendaItem",
      "description": "Agenda events collection"
    },
    "comments/{commentId}": {
      "schema": "Comment",
      "description": "User comments collection"
    }
  }
}
