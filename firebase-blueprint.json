{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile with role and settings",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user"
        },
        "role": {
          "type": "string",
          "enum": ["Administrador", "Analista", "Consultor", "Usuario Registrado", "Usuario Invitado"],
          "description": "User's role for RBAC"
        },
        "email": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "photoURL": {
          "type": "string"
        },
        "createdAt": {
          "type": "timestamp"
        },
        "updatedAt": {
          "type": "timestamp"
        }
      },
      "required": ["userId", "role", "email"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    }
  }
}
